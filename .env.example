# Database & output
LOL_DB_PATH=lol.db
LOL_LOGS_DIR=logs
LOL_EXPORT_DIR=exports

# Sources
LOL_GOL_BASE_URL=https://gol.gg
LOL_LOLTV_BASE_URL=https://www.loltv.gg
LOL_LEAGUEPEDIA_BASE_URL=https://liquipedia.net/leagueoflegends

# Regions (comma-separated)
LOL_TARGET_REGIONS=LCK,LPL,LEC,LCP,LCS

# Rate limits & concurrency (keep conservative)
LOL_CONCURRENCY=2
LOL_BROWSER_CONCURRENCY=1
LOL_RATE_LIMIT_SECONDS=1.5
LOL_REQUEST_TIMEOUT_SECONDS=30.0

# Browser fingerprint seed for JS-heavy sources
LOL_FINGERPRINT_SEED=42069

# Identify your bot — set a real contact email
LOL_USER_AGENT=LoLEsportsResearchBot/0.1 (+https://github.com/ark-daemon/lol-esports-scraper; contact: you@example.com)
